{
  "expo": {
    "name": "Alenio",
    "slug": "alenio",
    "scheme": "vibecode",
    "version": "1.0.03",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "f40ec24d-0b09-4cc6-8746-805bd60e9ea2"
      },
      "router": {}
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibecode.alenio-9iqp9v",
      "buildNumber": "28",
      "entitlements": {
        "aps-environment": "production"
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Alenio uses the camera to capture photos inside the app before you publish them.",
        "NSMicrophoneUsageDescription": "Alenio uses the microphone to record audio clips that stay with your in-app creations.",
        "NSPhotoLibraryUsageDescription": "Alenio accesses your photo library to generate thumbnails for your videos.",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSPhotoLibraryAddUsageDescription": "Alenio saves media you export from the app into your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "package": "com.vibecode.alenio9iqp9v",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-media-library",
        {
          "photosPermission": "Alenio accesses your photos to share images in chat and set profile and team pictures.",
          "savePhotosPermission": "Alenio saves media you download from messages into your photo library.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Alenio accesses your photos to share images in chat and set profile and team pictures."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./icon.png",
          "color": "#2D5A3D",
          "sounds": [
            "./src/assets/sounds/bell.wav",
            "./src/assets/sounds/tritone.wav",
            "./src/assets/sounds/chime.wav",
            "./src/assets/sounds/glass.wav",
            "./src/assets/sounds/aurora.wav",
            "./src/assets/sounds/chord.wav",
            "./src/assets/sounds/circles.wav",
            "./src/assets/sounds/complete.wav",
            "./src/assets/sounds/note.wav",
            "./src/assets/sounds/popcorn.wav",
            "./src/assets/sounds/pulse.wav",
            "./src/assets/sounds/synth.wav",
            "./src/assets/sounds/ding.wav",
            "./src/assets/sounds/achievement.wav",
            "./src/assets/sounds/beep.wav",
            "./src/assets/sounds/quickwin.wav",
            "./src/assets/sounds/digital.wav",
            "./src/assets/sounds/pop.wav",
            "./src/assets/sounds/clarity.wav",
            "./src/assets/sounds/alert.wav",
            "./src/assets/sounds/softbell.wav",
            "./src/assets/sounds/cheer.wav"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "gradleVersion": "8.10.2",
            "gradlePluginVersion": "8.7.3",
            "kotlinVersion": "2.0.21"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "icon": "./icon.png"
  }
}