{
  "expo": {
    "name": "Alenio",
    "slug": "alenio",
    "scheme": "vibecode",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibecode.alenio-9iqp9v",
      "buildNumber": "3",
      "infoPlist": {
        "NSCameraUsageDescription": "Alenio uses your camera for video calls and profile photos.",
        "NSMicrophoneUsageDescription": "Alenio uses your microphone for team video calls.",
        "NSPhotoLibraryUsageDescription": "Alenio accesses your photos to share images with your team.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.vibecode.alenio9iqp9v"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-av",
      [
        "expo-image-picker",
        {
          "photosPermission": "Alenio accesses your photos to share images in chats."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "gradleVersion": "8.10.2",
            "gradlePluginVersion": "8.7.3",
            "kotlinVersion": "2.0.21"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "icon": "./icon.png"
  }
}
