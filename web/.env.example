# Copy to .env — restart `bun run dev` after edits.

VITE_NEON_AUTH_URL=
# Add your Firebase / production site origin in Neon Console → Auth → Configuration → Domains
# (https://your-project.web.app — no path, no trailing slash). Not required for email sign-in unless you pass callbackURL.
# Keep as localhost; the dev proxy forwards /api to this machine when VITE_DEV_API_PROXY=1.
VITE_BACKEND_URL=http://127.0.0.1:3000

# ── iPad / same Wi‑Fi (recommended) ─────────────────────────────────────────
# 1. On your Mac: `cd backend && bun run dev` (API on :3000).
# 2. In .env below: set VITE_DEV_SERVER_ORIGIN to the exact URL you open on the iPad, e.g.:
#    VITE_DEV_SERVER_ORIGIN=http://192.168.1.41:5173
# 3. Turn on the proxy so the iPad only uses port 5173 (no firewall hole for 3000 on the tablet path):
VITE_DEV_API_PROXY=1
# 4. `cd web && bun run dev` — on iPad Safari open that same http://192.168...:5173 URL.

# Optional: if the API is not on 3000
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:3000

# ── Backend (Railway / local) for Stripe web billing ─────────────────────────
# Required on the API process for "Upgrade to Team" checkout to work (any environment):
#   STRIPE_SECRET_KEY=sk_test_...
#   STRIPE_TEAM_PRICE_ID=price_...
#   WEB_PUBLIC_URL=http://127.0.0.1:5173   # exact origin users use in the browser (no trailing slash)
# Optional: STRIPE_WEBHOOK_SECRET=whsec_... (webhooks)
