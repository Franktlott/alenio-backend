# Copy to .env — restart `npm run dev` after edits.

# Which server to use locally: development | production
VITE_API_TARGET=development

# ── Development ───────────────────────────────────────────────────────────────
# Auth (Better Auth) is served from this same backend URL under /api/auth
VITE_DEV_BACKEND_URL=

# ── Production ────────────────────────────────────────────────────────────────
VITE_PROD_BACKEND_URL=

# Optional legacy (no longer required for web login — Neon Auth URLs retired in Phase 3)
# VITE_DEV_NEON_AUTH_URL=
# VITE_PROD_NEON_AUTH_URL=

# Optional: Postgres URLs for local backend / Prisma (no VITE_ prefix — not sent to the browser).
# Copy from Neon Console → Connection string. Synced to backend/.env via `cd backend && bun run sync-env`.
# DEV_DATABASE_URL=
# PROD_DATABASE_URL=

# Mobile app handoff (invite links opened on a phone browser)
VITE_APP_SCHEME=alenio
VITE_IOS_APP_STORE_URL=
VITE_ANDROID_PLAY_STORE_URL=
