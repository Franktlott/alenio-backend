{
  "expo": {
    "name": "Alenio Go",
    "slug": "alenio-go-kiosk",
    "scheme": "aleniogo",
    "version": "0.1.0",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lotttechnologies.aleniogo",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.lotttechnologies.aleniogo",
      "edgeToEdgeEnabled": false
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#4361EE"
        }
      ]
    ],
    "icon": "../mobile/icon.png"
  }
}
