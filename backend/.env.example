# Copy to .env and fill in values. Restart the server after edits.
# cp .env.example .env
#
# DATABASE_URL can be synced from web/.env — run:
#   bun run sync-env
# Or edit web/.env and set DEV_DATABASE_URL / PROD_DATABASE_URL there.

# ── Required for login ─────────────────────────────────────────────────────
# Self-hosted Better Auth. When set (32+ chars) with Postgres DATABASE_URL,
# the API mounts /api/auth/* against the neon_auth schema.
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Microsoft Entra sign-in (optional; separate from calendar OAuth)
# Redirect URI in Entra: https://YOUR-API-HOST/api/auth/callback/microsoft
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common

# ── Core (defaults work for local) ─────────────────────────────────────────
DATABASE_URL=file:./dev.db
BACKEND_URL=http://localhost:3000
PORT=3000

# ── Web billing (checkout, customer portal, webhooks) ────────────────────────
# Secret key (sk_test_... or sk_live_...) from your billing provider dashboard
STRIPE_SECRET_KEY=

# Recurring Team plan price id (price_...) from the same dashboard
STRIPE_TEAM_PRICE_ID=

# Exact origin of the web app, NO trailing slash. Checkout/Portal return URLs use this.
# Local:   http://127.0.0.1:5173
# Hosted:  https://your-app.web.app
WEB_PUBLIC_URL=

# Webhook signing secret (whsec_...) — endpoint on this API: https://YOUR-API-HOST/api/webhooks/stripe
# Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=

# ── Optional ─────────────────────────────────────────────────────────────────
# CORS: comma-separated extra origins (localhost / 192.168.* / 10.* / *.web.app / *.firebaseapp.com / https://alenio.com / https://alenio.app are built in).
# CORS_ALLOWED_ORIGINS=https://staging.example.com,https://another-host.com

# NODE_ENV=development
# RESEND_API_KEY=
# FROM_EMAIL=noreply@alenio.com
# DAILY_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_STORAGE_BUCKET=
# OpenAI (Seneca coaching assistant — set on Railway for production, backend/.env for local)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Optional Neon Management API (account deletion helpers only — not used for login)
# NEON_API_KEY=
# NEON_PROJECT_ID=
# NEON_BRANCH_ID=
