model ChecklistLocationItem {
  id         String            @id @default(cuid())
  locationId String
  title      String
  note       String?
  category   String?
  sortOrder  Int               @default(0)
  location   ChecklistLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
}

model ChecklistLocationSubmission {
  id            String            @id @default(cuid())
  locationId    String
  submittedAt   DateTime          @default(now())
  submitterName String?
  responses     Json
  checkedCount  Int
  totalCount    Int
  isComplete    Boolean
  location      ChecklistLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, submittedAt])
