generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  teamMembers   TeamMember[]
  tasksCreated  Task[]           @relation("TaskCreator")
  assignments   TaskAssignment[]
  messagesSent  Message[]
  conversations ConversationParticipant[]
  directMessages DirectMessage[]
  messageReactions MessageReaction[]
  directMessageReactions DirectMessageReaction[]
  teamChatPins TeamChatPin[] @relation("TeamChatPinPinner")
  conversationPins ConversationPin[] @relation("ConversationPinPinner")
  templatesCreated TaskTemplate[] @relation("TemplateCreator")
  oneOnOneTemplatesCreated OneOnOneTemplate[] @relation("OneOnOneTemplateCreator")
  oneOnOneMeetingsCreated OneOnOneMeeting[] @relation("OneOnOneMeetingCreator")
  developmentGoalsCreated DevelopmentGoal[] @relation("DevelopmentGoalCreator")
  developmentGoalNotesCreated DevelopmentGoalNote[] @relation("DevelopmentGoalNoteCreator")
  phoneNumber   String?
  phoneNumberVerified Boolean @default(false)
  pushToken     String?
  personalBestStreak Int @default(0)
  personalBestCelebrated Boolean @default(false)
  notifMessages     Boolean @default(true)
  notifTaskAssigned Boolean @default(true)
  notifTaskDue      Boolean @default(true)
  notifMeetings     Boolean @default(true)
  /** Platform admin push: new user signups + member joins */
  notifAdminUsers       Boolean @default(true)
  /** Platform admin push: new workplaces */
  notifAdminWorkspaces  Boolean @default(true)
  /** Platform admin push: paid / canceled / past_due subscriptions */
  notifAdminBilling     Boolean @default(true)
  notifTone         String  @default("default")
  timezone          String?
  isAdmin           Boolean @default(false)
  joinRequests  JoinRequest[]
  teamInvitesSent TeamInvite[] @relation("TeamInvitesSent")
  teamInvitesAccepted TeamInvite[] @relation("TeamInvitesAccepted")
  calendarEvents CalendarEvent[]
  calendarConnections CalendarConnection[]
  externalCalendarEvents ExternalCalendarEvent[]
  activities    TeamActivity[]
  createdTopics Topic[] @relation("TopicCreator")
  topicMemberships TopicMember[]
  activityReactions TeamActivityReaction[]
  pollsCreated  Poll[]     @relation("PollCreatedBy")
  pollVotes     PollVote[] @relation("PollVoteUser")
  subtaskCompletions SubtaskCompletion[]
  organizationMemberships OrganizationMembership[]
  organizationScimUsers OrganizationScimUser[]
  organizationSignupInvitesAccepted OrganizationSignupInvite[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Company / enterprise-contract account above workspaces (SSO, SCIM, multi-workspace).
/// Distinct from self-serve paid tiers on TeamSubscription (free / Pro / Operations via Stripe).
model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  /** "active" | "suspended" */
  status        String   @default("active")
  /**
   * "enterprise" = Alenio Enterprise contract customer (Admin → Enterprise customers).
   * "workspace" = SSO/SCIM shell created from a normal workspace (not a contract customer).
   */
  accountType   String   @default("enterprise")
  /** Max workspaces this enterprise customer may create (set by Alenio). */
  workspaceLimit Int      @default(5)
  /** When true, users on verified org domains must use this org's SSO (not password / shared Microsoft). */
  ssoRequired   Boolean  @default(false)
  /** Optional workspace new SSO users join first. */
  defaultTeamId String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  defaultTeam  Team?                     @relation("OrgDefaultTeam", fields: [defaultTeamId], references: [id], onDelete: SetNull)
  teams        Team[]                    @relation("OrgWorkspaces")
  domains      OrganizationDomain[]
  ssoConfig    OrganizationSsoConfig?
  scimConfig   OrganizationScimConfig?
  memberships  OrganizationMembership[]
  scimUsers    OrganizationScimUser[]
  signupInvites OrganizationSignupInvite[]
  goModules    OrganizationModule[]
  walkLibraryItems WalkLibraryItem[]
}

/// Verified email domains that route login to an organization (e.g. acme.com).
model OrganizationDomain {
  id             String    @id @default(cuid())
  organizationId String
  /** Normalized hostname only, lowercase, no @ (e.g. acme.com). */
  domain         String    @unique
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

/// Per-organization identity provider settings (Entra / Okta / Google / SAML).
model OrganizationSsoConfig {
  id               String   @id @default(cuid())
  organizationId   String   @unique
  /** "microsoft" | "okta" | "google" | "saml" | custom */
  provider         String
  /** "oidc" | "saml" */
  protocol         String   @default("oidc")
  issuer           String?
  metadataUrl      String?
  clientId         String?
  /** Encrypted secret or secret-manager reference — never return to clients. */
  clientSecretEnc  String?
  /** Microsoft Entra tenant GUID when provider = microsoft. */
  tenantId         String?
  /** SAML IdP SSO URL */
  entryPoint       String?
  /** SAML IdP signing certificate (PEM) */
  cert             String?
  enabled          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

/// SCIM 2.0 provisioning credentials for an organization (Okta → Alenio directory sync).
model OrganizationScimConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique
  enabled        Boolean  @default(false)
  /** SHA-256 hex of the bearer token. */
  tokenHash      String?
  /** First characters of the token for admin display (not secret). */
  tokenPrefix    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

/// SCIM-managed user link for an organization (tracks active + userName independently of User).
model OrganizationScimUser {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  userName       String
  externalId     String?
  active         Boolean  @default(true)
  givenName      String?
  familyName     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userName])
  @@unique([organizationId, userId])
  @@index([organizationId, active])
  @@index([userId])
}

/// Company-level membership (separate from TeamMember workspace roles).
model OrganizationMembership {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  /** "org_owner" | "org_admin" | "org_member" */
  role           String   @default("org_member")
  joinedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
}

/// Enterprise org-owned Alenio Go module (corporate standards).
/// status: draft | published | archived
model OrganizationModule {
  id             String   @id @default(cuid())
  organizationId String
  moduleKey      String
  moduleName     String
  status         String   @default("draft")
  /** Org-wide defaults (limits, photos, signatures, offline, branding, languages). */
  defaultsJson   Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments      OrganizationModuleAssignment[]
  workspaceModules WorkspaceModule[]

  @@unique([organizationId, moduleKey])
  @@index([organizationId])
}

/// How an org module is rolled out to workspaces. scope: organization | workspaces
model OrganizationModuleAssignment {
  id                      String   @id @default(cuid())
  organizationModuleId    String
  scope                   String   @default("organization")
  allowScheduleEdits      Boolean  @default(true)
  allowEquipmentAdditions Boolean  @default(true)
  allowLocalNotes         Boolean  @default(true)
  allowLocalNotifications Boolean  @default(true)
  /** Template/SOP edits locked unless explicitly allowed. */
  allowTemplateEdits      Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  organizationModule OrganizationModule                @relation(fields: [organizationModuleId], references: [id], onDelete: Cascade)
  teams              OrganizationModuleAssignmentTeam[]

  @@index([organizationModuleId])
}

model OrganizationModuleAssignmentTeam {
  id           String @id @default(cuid())
  assignmentId String
  teamId       String

  assignment OrganizationModuleAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  team       Team                         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, teamId])
  @@index([teamId])
}

model Team {
  id          String       @id @default(cuid())
  /** Trimmed in API; unique so two workspaces cannot share the same name (case-insensitive check in routes). */
  name        String       @unique
  image       String?
  inviteCode  String       @unique
  /** Optional parent company for SSO / multi-workspace orgs. Null = standalone workspace. */
  organizationId String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  organization Organization? @relation("OrgWorkspaces", fields: [organizationId], references: [id], onDelete: SetNull)
  orgDefaultFor Organization? @relation("OrgDefaultTeam")
  members     TeamMember[]
  tasks       Task[]
  messages    Message[]
  templates   TaskTemplate[]
  joinRequests JoinRequest[]
  teamInvites TeamInvite[]
  calendarEvents CalendarEvent[]
  subscription  TeamSubscription?
  teamActivities TeamActivity[]
  topics      Topic[]
  polls       Poll[]
  oneOnOneTemplates OneOnOneTemplate[]
  oneOnOneMeetings OneOnOneMeeting[]
  developmentGoals DevelopmentGoal[]
  recurrenceSeries RecurrenceSeries[]
  checklistLocations ChecklistLocation[]
  /** Public token for the workspace checklist hub (one QR per workspace). */
  checklistHubToken String? @unique
  /** JSON: per-workspace check-in and development goal expectations. */
  workplaceStandards String?
  /** JSON: Alenio Go kiosk presentation settings (hero image, etc.). */
  goFrontendSettings String?
  goLoginRequests GoLoginRequest[]
  workplaceAlerts WorkplaceAlert[]
  goDevicePresences GoDevicePresence[]
  briefings Briefing[]
  walkTemplates WalkTemplate[]
  walkCompletions WalkCompletion[]
  walkRuns WalkRun[]
  walkLibraryItems WalkLibraryItem[]
  walkOccurrences WalkOccurrence[]
  moduleAssignmentTeams OrganizationModuleAssignmentTeam[]
  conversations Conversation[]
  workspaceModules WorkspaceModule[]
  moduleTestSessions ModuleTestSession[]
  chatPins TeamChatPin[]

  @@index([organizationId])
}

/// Per-workspace lifecycle + operating mode for an Alenio module.
/// status: "inactive" | "active". operatingMode: "testing" | "live" | null (null when inactive).
model WorkspaceModule {
  id                     String    @id @default(cuid())
  teamId                 String
  /// Future-proofing for multi-workspace companies. Mirrors teamId today.
  companyId              String?
  moduleKey              String
  moduleName             String
  status                 String    @default("inactive")
  operatingMode          String?
  setupProgressPercent   Int       @default(0)
  setupCompletedAt       DateTime?
  activatedAt            DateTime?
  activatedByUserId      String?
  liveStartedAt          DateTime?
  liveStartedByUserId    String?
  testingStartedAt       DateTime?
  testingStartedByUserId String?
  // Testing access controls
  requireTestCode            Boolean   @default(false)
  testAccessCode             String?
  testCodeExpiresAt          DateTime?
  /// JSON string array of workplace ids allowed to see the module while testing.
  allowedTestingWorkplaceIds String?
  /// JSON string array of user ids allowed to see the module while testing.
  allowedTestingUserIds      String?
  /// JSON string array of roles allowed to see the module while testing.
  allowedTestingRoles        String?
  /// Optional link to the org module this workspace instance was synced from (enterprise).
  organizationModuleId String?
  createdAt              DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  organizationModule OrganizationModule? @relation(fields: [organizationModuleId], references: [id], onDelete: SetNull)

  @@unique([teamId, moduleKey])
  @@index([teamId])
  @@index([organizationModuleId])
}

/// Admin-only record of a testing session for a module (feeds the Testing Sessions view).
/// Execution/completion records created while a module is in testing mode should reference
/// testSessionId and set isTest = true; live records set isTest = false.
model ModuleTestSession {
  id               String    @id @default(cuid())
  teamId           String
  moduleKey        String
  testedByUserId   String?
  testerName       String?
  workplaceId      String?
  workplaceName    String?
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  durationSeconds  Int?
  completedSteps   Int       @default(0)
  failedSteps      Int       @default(0)
  notes            String?
  createdAt        DateTime  @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId, moduleKey])
}

model TeamSubscription {
  id                   String    @id @default(cuid())
  teamId               String    @unique
  team                 Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  plan                 String    @default("free")   // "free" | "team" | "operations" ("pro" legacy → team)
  status               String    @default("active") // "active" | "canceled" | "past_due"
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  /** Stripe cancel_at_period_end — team plan stays active until currentPeriodEnd. */
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model TeamMember {
  id            String @id @default(cuid())
  role          String @default("member")
  goPinHash     String?
  userId        String
  teamId        String
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team          Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  joinedAt      DateTime @default(now())
  currentStreak Int    @default(0)

  @@unique([userId, teamId])
  @@index([teamId])
  @@index([userId])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("todo")
  priority    String   @default("medium")
  dueDate     DateTime?
  completedAt   DateTime?
  archivedAt    DateTime?
  attachmentUrl String?
  incognito   Boolean  @default(false)
  isJoint     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  creatorId   String
  creator     User     @relation("TaskCreator", fields: [creatorId], references: [id])

  assignments    TaskAssignment[]
  recurrenceRule RecurrenceRule?
  subtasks       Subtask[]

  oneOnOneMeetingId String?
  oneOnOneMeeting   OneOnOneMeeting? @relation(fields: [oneOnOneMeetingId], references: [id], onDelete: SetNull)

  recurrenceSeriesId String?
  recurrenceSeries   RecurrenceSeries? @relation(fields: [recurrenceSeriesId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([recurrenceSeriesId])
  @@index([teamId, status])
  @@index([teamId, dueDate])
  @@index([teamId, completedAt])
  @@index([teamId, archivedAt])
  @@index([oneOnOneMeetingId])
}

model Subtask {
  id          String   @id @default(cuid())
  title       String
  completed   Boolean  @default(false)
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  order       Int      @default(0)
  completions SubtaskCompletion[]
}

model SubtaskCompletion {
  id          String   @id @default(cuid())
  subtaskId   String
  userId      String
  subtask     Subtask  @relation(fields: [subtaskId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([subtaskId, userId])
}

model TaskAssignment {
  id         String   @id @default(cuid())
  taskId     String
  userId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([taskId, userId])
  @@index([userId])
  @@index([taskId])
}

model RecurrenceRule {
  id         String   @id @default(cuid())
  taskId     String   @unique
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type       String
  interval   Int      @default(1)
  daysOfWeek String?
  dayOfMonth Int?
  nextDueAt  DateTime?
}

model RecurrenceSeries {
  id            String   @id @default(cuid())
  teamId        String
  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  creatorId     String
  title         String
  description   String?
  priority      String   @default("medium")
  incognito     Boolean  @default(false)
  isJoint       Boolean  @default(false)
  attachmentUrl String?
  type          String
  interval      Int      @default(1)
  occurrenceCount Int    @default(1)
  daysOfWeek    String?
  dayOfMonth    Int?
  timeZone      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tasks         Task[]

  @@index([teamId])
}

model TaskTemplate {
  id                   String   @id @default(cuid())
  title                String
  description          String?
  priority             String   @default("medium")
  attachmentUrl        String?
  subtasks             String?
  isRecurring          Boolean  @default(false)
  recurrenceType       String?
  recurrenceInterval   Int?
  recurrenceDaysOfWeek String?
  recurrenceDayOfMonth Int?
  incognito            Boolean  @default(false)
  isJoint              Boolean  @default(false)
  teamId               String
  team                 Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdById          String
  createdBy            User     @relation("TemplateCreator", fields: [createdById], references: [id])
  createdAt            DateTime @default(now())
}

model OneOnOneTemplate {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  title       String
  description String?
  /** JSON array of { id, label, type, order, required?, ratingMax? } */
  fields      String
  /** JSON array of leader-only prep reminders shown before starting a check-in */
  leaderPrep  String?
  libraryKey  String?
  createdById String
  createdBy   User     @relation("OneOnOneTemplateCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  meetings    OneOnOneMeeting[]

  @@index([teamId])
}

model OneOnOneMeeting {
  id             String            @id @default(cuid())
  teamId         String
  team           Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  memberUserId   String
  templateId     String?
  template       OneOnOneTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateTitle  String
  /** Snapshot of template fields at creation time */
  templateFields String
  /** JSON object: { [fieldId]: string | number } */
  responses      String
  /** draft = saved but not published; published = finalized check-in */
  status         String            @default("published")
  /** Set when first published; null while draft */
  publishedAt    DateTime?
  createdById    String
  createdBy      User              @relation("OneOnOneMeetingCreator", fields: [createdById], references: [id])
  createdAt      DateTime          @default(now())
  followUpTasks  Task[]

  @@index([teamId, memberUserId])
}

model DevelopmentGoal {
  id           String   @id @default(cuid())
  teamId       String
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  memberUserId String
  skill        String
  /** JSON string array of step labels */
  steps        String
  status         String   @default("active")
  closedAt       DateTime?
  /** Last progress update or goal edit — used for 30-day inactivity policy */
  lastActivityAt DateTime?
  createdById    String
  createdBy    User     @relation("DevelopmentGoalCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  notes        DevelopmentGoalNote[]

  @@index([teamId, memberUserId])
}

model DevelopmentGoalNote {
  id          String          @id @default(cuid())
  goalId      String
  goal        DevelopmentGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  body        String
  createdById String
  createdBy   User            @relation("DevelopmentGoalNoteCreator", fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())

  @@index([goalId])
}

model Message {
  id               String   @id @default(cuid())
  content          String?
  mediaUrl         String?
  mediaType        String?
  createdAt        DateTime @default(now())
  teamId           String
  team             Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  senderId         String
  sender           User     @relation(fields: [senderId], references: [id])
  replyToId        String?
  replyTo          Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies          Message[] @relation("MessageReplies")
  reactions        MessageReaction[]
  topicId          String?
  topic            Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)
  mentionedUserIds String   @default("[]")
  editedAt         DateTime?
  chatPins         TeamChatPin[]

  @@index([teamId, createdAt])
  @@index([topicId, createdAt])
}

model MessageReaction {
  id        String   @id @default(cuid())
  emoji     String
  userId    String
  messageId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
}

model Topic {
  id                      String        @id @default(cuid())
  name                    String
  description             String?
  color                   String        @default("#4361EE")
  /** Optional space photo URL */
  image                   String?
  /** UI icon key: leadership | overnight | food_safety | recognition | hash | users | ... */
  icon                    String        @default("hash")
  privacy                 TopicPrivacy  @default(open)
  autoAddWorkspaceMembers Boolean       @default(true)
  archivedAt              DateTime?
  teamId                  String
  createdById             String
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  team                    Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy               User          @relation("TopicCreator", fields: [createdById], references: [id])
  messages                Message[]
  polls                   Poll[]
  members                 TopicMember[]

  @@index([teamId, archivedAt])
}

enum TopicPrivacy {
  open
  private
}

model TopicMember {
  id        String          @id @default(cuid())
  topicId   String
  userId    String
  role      TopicMemberRole @default(member)
  joinedAt  DateTime        @default(now())
  topic     Topic           @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
  @@index([userId])
}

enum TopicMemberRole {
  owner
  admin
  member
}

model Conversation {
  id           String                    @id @default(cuid())
  name         String?
  isGroup      Boolean                   @default(false)
  /** Workspace the group was created in (used to label cross-workspace chat lists). */
  teamId       String?
  team         Team?                     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     DirectMessage[]
  pins         ConversationPin[]

  @@index([teamId])
}

model ConversationParticipant {
  id             String                       @id @default(cuid())
  conversationId String
  userId         String
  role           ConversationParticipantRole  @default(member)
  conversation   Conversation                 @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

enum ConversationParticipantRole {
  owner
  admin
  member
}

model DirectMessage {
  id             String       @id @default(cuid())
  content        String?
  mediaUrl       String?
  mediaType      String?
  createdAt      DateTime     @default(now())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  replyToId      String?
  replyTo        DirectMessage?  @relation("DMReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        DirectMessage[] @relation("DMReplies")
  reactions      DirectMessageReaction[]
  mentionedUserIds String     @default("[]")
  pins ConversationPin[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

/** Up to 5 pinned messages per Team Chat channel or Space. channelKey is "general" or a topic id. */
model TeamChatPin {
  id         String   @id @default(cuid())
  teamId     String
  channelKey String
  messageId  String
  pinnedAt   DateTime @default(now())
  pinnedById String
  sortOrder  Int      @default(0)
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy   User     @relation("TeamChatPinPinner", fields: [pinnedById], references: [id], onDelete: Cascade)

  @@unique([teamId, channelKey, messageId])
  @@index([teamId, channelKey, sortOrder])
}

/** Up to 5 pinned messages per DM / group conversation. */
model ConversationPin {
  id              String        @id @default(cuid())
  conversationId  String
  directMessageId String
  pinnedAt        DateTime      @default(now())
  pinnedById      String
  sortOrder       Int           @default(0)
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  directMessage   DirectMessage @relation(fields: [directMessageId], references: [id], onDelete: Cascade)
  pinnedBy        User          @relation("ConversationPinPinner", fields: [pinnedById], references: [id], onDelete: Cascade)

  @@unique([conversationId, directMessageId])
  @@index([conversationId, sortOrder])
}

model DirectMessageReaction {
  id              String        @id @default(cuid())
  emoji           String
  userId          String
  directMessageId String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  directMessage   DirectMessage @relation(fields: [directMessageId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([directMessageId, userId, emoji])
}

model JoinRequest {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  status    String   @default("pending") // pending, approved, rejected
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model GoLoginRequest {
  id               String   @id @default(cuid())
  teamId           String
  deviceId         String
  deviceLabel      String?
  status           String   @default("pending") // pending, approved, rejected
  approvedByUserId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, deviceId])
  @@index([teamId, status])
}

model WorkplaceAlert {
  id              String   @id @default(cuid())
  teamId          String
  title           String
  body            String
  targetType      String   // device, all_devices, all_users
  targetDeviceId  String?
  playSound       Boolean  @default(true)
  createdByUserId String
  createdAt       DateTime @default(now())

  team Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  acks WorkplaceAlertAck[]

  @@index([teamId, createdAt])
}

model WorkplaceAlertAck {
  id        String   @id @default(cuid())
  alertId   String
  deviceId  String
  createdAt DateTime @default(now())

  alert WorkplaceAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([alertId, deviceId])
}

model GoDevicePresence {
  id          String   @id @default(cuid())
  teamId      String
  deviceId    String
  deviceLabel String?
  lastSeenAt  DateTime @default(now()) @updatedAt
  createdAt   DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, deviceId])
  @@index([teamId, lastSeenAt])
}

model Briefing {
  id               String    @id @default(cuid())
  teamId           String
  title            String
  description      String
  documentUrl      String
  documentFilename String?
  contentType      String?
  dueAt            DateTime?
  requireSignature Boolean   @default(false)
  allowInitials    Boolean   @default(true)
  publishedAt      DateTime  @default(now())
  createdByUserId  String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  team        Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  completions BriefingCompletion[]

  @@index([teamId, publishedAt])
}

model BriefingCompletion {
  id            String   @id @default(cuid())
  briefingId    String
  teamId        String
  completionKey String
  userId        String?
  deviceId      String?
  reviewerName  String?
  initials      String
  signatureData String?
  documentUrl   String
  completedAt   DateTime @default(now())

  briefing Briefing @relation(fields: [briefingId], references: [id], onDelete: Cascade)

  @@unique([briefingId, completionKey])
  @@index([teamId, completedAt])
}

/// Workspace reusable inspection item (catalog head). status: ACTIVE | ARCHIVED
/// Owned by a workspace (teamId) OR an enterprise organization (organizationId) — not both.
model WalkLibraryItem {
  id               String   @id @default(cuid())
  teamId           String?
  organizationId   String?
  name             String
  description      String?
  category         String   @default("Custom")
  type             String
  status           String   @default("ACTIVE")
  currentVersion   Int      @default(1)
  createdByUserId  String
  updatedByUserId  String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  team         Team?                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  organization Organization?            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions     WalkLibraryItemVersion[]
  placements   WalkTemplatePlacement[]

  @@index([teamId, status])
  @@index([teamId, type])
  @@index([teamId, category])
  @@index([organizationId, status])
  @@index([organizationId, type])
}

/// Immutable library item configuration. Edits create a new version row.
model WalkLibraryItemVersion {
  id              String   @id @default(cuid())
  libraryItemId   String
  version         Int
  name            String
  description     String?
  instructions    String?
  requiredDefault Boolean  @default(true)
  config          Json     @default("{}")
  deviceMethods   Json     @default("{}")
  createdByUserId String
  createdAt       DateTime @default(now())

  libraryItem       WalkLibraryItem         @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  correctiveActions WalkCorrectiveAction[]
  placements        WalkTemplatePlacement[]

  @@unique([libraryItemId, version])
  @@index([libraryItemId])
}

/// Walk Builder template. status: DRAFT | PUBLISHED | ARCHIVED
model WalkTemplate {
  id                       String    @id @default(cuid())
  teamId                   String
  name                     String
  description              String?
  workplace                String    @default("")
  scoringEnabled           Boolean   @default(true)
  /// Kept in sync with status !== ARCHIVED for legacy indexes.
  isActive                 Boolean   @default(true)
  status                   String    @default("DRAFT")
  version                  Int       @default(1)
  estimatedDurationMinutes Int?
  publishedAt              DateTime?
  publishedByUserId        String?
  parentTemplateId         String?
  createdByUserId          String
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  team        Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sections    WalkTemplateSection[]
  items       WalkTemplateItem[]
  placements  WalkTemplatePlacement[]
  versions    WalkTemplateVersion[]
  schedules   WalkSchedule[]
  completions WalkCompletion[]
  runs        WalkRun[]
  occurrences WalkOccurrence[]

  @@index([teamId, isActive])
  @@index([teamId, status])
}

model WalkTemplateSection {
  id          String                  @id @default(cuid())
  templateId  String
  title       String
  description String?
  sortOrder   Int                     @default(0)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  template    WalkTemplate            @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items       WalkTemplateItem[]
  placements  WalkTemplatePlacement[]

  @@index([templateId])
}

/// Legacy embedded item — prefer WalkTemplatePlacement + library. Kept for dual-read/migration.
model WalkTemplateItem {
  id              String   @id @default(cuid())
  templateId      String
  sectionId       String?
  type            String   @default("YES_NO")
  label           String
  description     String?
  instructions    String?
  sortOrder       Int      @default(0)
  required        Boolean  @default(true)
  failureBehavior String?
  config          Json     @default("{}")
  /// Set after backfill into WalkLibraryItem.
  libraryItemId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  template        WalkTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  section         WalkTemplateSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([sectionId])
}

/// Draft walk composition: pinned library item version + walk-local overrides.
model WalkTemplatePlacement {
  id                    String   @id @default(cuid())
  templateId            String
  sectionId             String?
  sortOrder             Int      @default(0)
  libraryItemId         String
  libraryItemVersionId  String
  requiredOverride      Boolean?
  instructionsOverride  String?
  titleOverride         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  template            WalkTemplate            @relation(fields: [templateId], references: [id], onDelete: Cascade)
  section             WalkTemplateSection?    @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  libraryItem         WalkLibraryItem         @relation(fields: [libraryItemId], references: [id], onDelete: Restrict)
  libraryItemVersion  WalkLibraryItemVersion  @relation(fields: [libraryItemVersionId], references: [id], onDelete: Restrict)

  @@index([templateId])
  @@index([sectionId])
  @@index([libraryItemId])
  @@index([libraryItemVersionId])
}

/// Immutable published walk snapshot.
model WalkTemplateVersion {
  id                String   @id @default(cuid())
  templateId        String
  version           Int
  snapshot          Json
  publishedAt       DateTime @default(now())
  publishedByUserId String?

  template    WalkTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  schedules   WalkSchedule[]
  occurrences WalkOccurrence[]

  @@unique([templateId, version])
  @@index([templateId])
}

/// Legacy flat completion — unused by Walk Builder; prefer WalkRun.
model WalkCompletion {
  id                  String   @id @default(cuid())
  teamId              String
  templateId          String
  walkName            String
  workplace           String
  completedByUserId   String
  completedByName     String
  completedAt         DateTime @default(now())
  scoringEnabled      Boolean  @default(true)
  score               Int?
  totalReviewed       Int
  passCount           Int
  needsAttentionCount Int
  naCount             Int
  photosCount         Int      @default(0)
  finalNotes          String?
  responses           Json

  team     Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  template WalkTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([teamId, completedAt])
  @@index([templateId, completedAt])
}

model WalkSchedule {
  id                       String    @id @default(cuid())
  templateId               String
  templateVersionId        String?
  name                     String?
  timezone                 String    @default("America/New_York")
  recurrence               String    @default("DAILY")
  daysOfWeek               Json?
  intervalMinutes          Int?
  effectiveFrom            DateTime  @default(now())
  effectiveTo              DateTime?
  assignScope              String    @default("WORKSPACE")
  assignRole               String?
  assignTeamId             String?
  assignUserIds            Json?
  completionMode           String    @default("ANY_ONE")
  claimMode                String    @default("FIRST_START_OWNS")
  managerApprovalRequired  Boolean   @default(false)
  requiredCompletionCount  Int       @default(1)
  missedBehavior           String    @default("MARK_MISSED")
  notifyEnabled            Boolean   @default(true)
  isActive                 Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  template        WalkTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateVersion WalkTemplateVersion? @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  windows         WalkScheduleWindow[]
  occurrences     WalkOccurrence[]

  @@index([templateId, isActive])
}

model WalkScheduleWindow {
  id           String @id @default(cuid())
  scheduleId   String
  /// Minutes from midnight local (0–1439).
  startMinutes Int
  dueMinutes   Int
  graceMinutes Int    @default(0)
  sortOrder    Int    @default(0)

  schedule WalkSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
}

/// status: UPCOMING | AVAILABLE | IN_PROGRESS | COMPLETED | COMPLETED_LATE | MISSED | CANCELLED
model WalkOccurrence {
  id                String    @id @default(cuid())
  teamId            String
  scheduleId        String
  scheduleWindowId  String?
  templateId        String
  templateVersionId String
  windowStart       DateTime
  dueAt             DateTime
  graceEndsAt       DateTime
  status            String    @default("UPCOMING")
  assignScope       String    @default("WORKSPACE")
  assignRole        String?
  assignUserIds     Json?
  startedByUserId   String?
  completedByUserId String?
  startedAt         DateTime?
  completedAt       DateTime?
  score             Int?
  runId             String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  team            Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  schedule        WalkSchedule        @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  template        WalkTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateVersion WalkTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  run             WalkRun?            @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@unique([scheduleId, windowStart])
  @@index([teamId, windowStart])
  @@index([teamId, status, dueAt])
  @@index([templateId, windowStart])
}

/// status: IN_PROGRESS | COMPLETED | ABANDONED
model WalkRun {
  id                String    @id @default(cuid())
  teamId            String
  templateId        String
  templateVersion   Int
  /// Frozen template snapshot at run start.
  templateSnapshot  Json
  status            String    @default("IN_PROGRESS")
  startedByUserId   String?
  startedByName     String?
  deviceId          String?
  isTest            Boolean   @default(false)
  testSessionId     String?
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  score             Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  team       Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  template   WalkTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  responses  WalkItemResponse[]
  occurrence WalkOccurrence?

  @@index([teamId, startedAt])
  @@index([templateId, startedAt])
}

/// status: NOT_STARTED | PASS | FAIL | NEEDS_ACTION | RESOLVED | NOT_APPLICABLE
model WalkItemResponse {
  id          String    @id @default(cuid())
  runId       String
  itemId      String
  itemType    String
  status      String    @default("NOT_STARTED")
  response    Json?
  failed      Boolean   @default(false)
  notes       String?
  photoUrls   Json?
  completedBy String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  run                     WalkRun                       @relation(fields: [runId], references: [id], onDelete: Cascade)
  correctiveActionResults WalkCorrectiveActionResult[]

  @@unique([runId, itemId])
  @@index([runId])
}

/// Corrective actions belong to a library item version (immutable with that version).
model WalkCorrectiveAction {
  id                   String   @id @default(cuid())
  libraryItemVersionId String
  trigger              String   @default("ON_FAIL")
  actionType           String
  title                String
  instructions         String?
  position             Int      @default(0)
  required             Boolean  @default(true)
  /// When true, walk cannot complete until this action is done.
  blocksCompletion     Boolean  @default(false)
  config               Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  libraryItemVersion WalkLibraryItemVersion @relation(fields: [libraryItemVersionId], references: [id], onDelete: Cascade)

  @@index([libraryItemVersionId])
}

/// Progress for a failure-procedure step on a run item.
/// `correctiveActionId` is the snapshot action id (not an FK) so published walks still work
/// if the library action row was later replaced/deleted.
model WalkCorrectiveActionResult {
  id                 String    @id @default(cuid())
  itemResponseId     String
  correctiveActionId String
  status             String    @default("PENDING")
  response           Json?
  completedBy        String?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  itemResponse WalkItemResponse @relation(fields: [itemResponseId], references: [id], onDelete: Cascade)

  @@unique([itemResponseId, correctiveActionId])
  @@index([itemResponseId])
}

model TeamInvite {
  id             String    @id @default(cuid())
  teamId         String
  email          String
  invitedById    String
  token          String    @unique
  status         String    @default("pending") // pending, accepted, cancelled
  acceptedUserId String?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime
  acceptedAt     DateTime?

  team         Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy    User  @relation("TeamInvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedUser User? @relation("TeamInvitesAccepted", fields: [acceptedUserId], references: [id], onDelete: SetNull)

  @@index([teamId, status])
  @@index([email, status])
}

/** Invite for a new enterprise owner to create their Alenio account (name + password). */
model OrganizationSignupInvite {
  id                    String    @id @default(cuid())
  organizationId        String
  email                 String
  suggestedName         String?
  token                 String    @unique
  status                String    @default("pending") // pending, accepted, cancelled
  pendingWorkspaceName  String?
  pendingPlan           String?
  acceptedUserId        String?
  createdAt             DateTime  @default(now())
  expiresAt             DateTime
  acceptedAt            DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  acceptedUser User?        @relation(fields: [acceptedUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([email, status])
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(true)
  color       String    @default("#4361EE")
  isHidden    Boolean   @default(false)
  isVideoMeeting Boolean @default(false)
  isOneOnOne Boolean @default(false)
  oneOnOneMemberUserId String?
  oneOnOneTemplateId String?
  approvalStatus String @default("approved")
  reminderMinutes String  @default("[]")
  teamId      String
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  team      Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([teamId, startDate])
}

model CalendarConnection {
  id                   String    @id @default(cuid())
  userId               String
  provider             String
  accountEmail         String?
  externalCalendarId   String?
  externalCalendarName String?
  accessTokenEnc       String?
  refreshTokenEnc      String
  accessTokenExpiresAt DateTime?
  lastSyncedAt         DateTime?
  syncError            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  events ExternalCalendarEvent[]

  @@unique([userId, provider])
  @@index([userId])
}

model ExternalCalendarEvent {
  id              String   @id @default(cuid())
  userId          String
  connectionId    String
  externalEventId String
  startDate       DateTime
  endDate         DateTime?
  allDay          Boolean  @default(false)
  titleDisplay    String   @default("Busy")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection CalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, externalEventId])
  @@index([userId, startDate])
}

model TeamActivity {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      String
  metadata  String?
  createdAt DateTime @default(now())
  reactions TeamActivityReaction[]

  @@index([teamId, createdAt])
}

model TeamActivityReaction {
  id         String       @id @default(cuid())
  emoji      String
  userId     String
  activityId String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity   TeamActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@unique([activityId, userId, emoji])
}

model Poll {
  id          String       @id @default(cuid())
  teamId      String
  topicId     String?
  createdById String
  question    String
  endsAt      DateTime
  createdAt   DateTime     @default(now())
  allowLeaderDelete Boolean      @default(true)
  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  topic       Topic?       @relation(fields: [topicId], references: [id], onDelete: SetNull)
  createdBy   User         @relation("PollCreatedBy", fields: [createdById], references: [id])
  options     PollOption[]
  votes       PollVote[]
}

model PollOption {
  id     String     @id @default(cuid())
  pollId String
  text   String
  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes  PollVote[]
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime   @default(now())
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user      User       @relation("PollVoteUser", fields: [userId], references: [id])

