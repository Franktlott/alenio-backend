    "typescript": "5.8.3"
  },
  "dependencies": {
    "@hono/node-server": "1.12.0",
    "@hono/zod-validator": "^0.7.6",
    "@neondatabase/auth": "^0.2.0-beta.1",
    "@prisma/client": "6",
    "bcryptjs": "^3.0.3",
    "better-auth": "1.4.18",
    "done": "^1.1.8",
    "firebase-admin": "^13.8.0",
    "hono": "4.6.0",
    "jose": "^6.2.2",
    "pg": "^8.22.0",
    "resend": "^6.10.0",
    "stripe": "^22.1.1",
    "zod": "4.1.11"
  }
