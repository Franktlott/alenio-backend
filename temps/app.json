{
  "expo": {
    "name": "Alenio Temps",
    "slug": "alenio-temps",
    "scheme": "aleniotemps",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lotttechnologies.aleniotemps",
      "deploymentTarget": "16.4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSBluetoothAlwaysUsageDescription": "Alenio Temps uses Bluetooth to communicate with ThermoWorks temperature probes.",
        "NSBluetoothPeripheralUsageDescription": "Alenio Temps uses Bluetooth to communicate with ThermoWorks temperature probes.",
        "UIApplicationSceneManifest": {
          "UIApplicationSupportsMultipleScenes": false,
          "UISceneConfigurations": {
            "UIWindowSceneSessionRoleApplication": [
              {
                "UISceneConfigurationName": "Default Configuration",
                "UISceneDelegateClassName": "$(PRODUCT_MODULE_NAME).SceneDelegate"
              }
            ]
          }
        }
      }
    },
    "android": {
      "package": "com.lotttechnologies.aleniotemps",
      "edgeToEdgeEnabled": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "usePrecompiledModules": false,
            "buildReactNativeFromSource": true
          },
          "android": {
            "minSdkVersion": 24
          }
        }
      ],
      "./plugins/withIosSceneLifecycle",
      "alenio-thermoworks",
      [
        "expo-splash-screen",
        {
          "image": "./assets/alenio-temp.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ]
    ],
    "icon": "../mobile/icon.png",
    "splash": {
      "image": "./assets/alenio-temp.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
